<!DOCTYPE ZTMF>
<meta>
title = "Zavorateam Website"
icon = "../assets/favicon.svg"
style = "../assets/common_styles.css"
rmb_menu = False
type = "main"
style {
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: auto;
            touch-action: pan-y;
            overscroll-behavior: none;
        }

        canvas { position: fixed; top:0; left:0; z-index:-1; display:block; }
    </style>
}
</meta>
<body>
