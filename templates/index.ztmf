            <a class="link" href="https://www.figma.com/make/et9yvcY3OUVLduTbrzVz0L/3D-Music-Visualizer-Project?fullscreen=1">Музыка в 3Д пространстве</a>
            <h6 style="margin-top: 19px;height: 0px;">Thanks to <a href="https://alexgyver.github.io/alexgyver.github.io">AlexGyver</a></h6>
        </div>
    </main>
}
components = bg {<canvas bg="cubic" width="1920" height="1080"></canvas>}, theme {bottom-right}
</body>
